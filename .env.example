# ─────────────────────────────────────────────
# LateralShield Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# MongoDB
MONGO_URI=mongodb://admin:lateralshield2026@localhost:27017/lateralshield?authSource=admin
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=lateralshield2026

# Flask Backend
PORT=5000
FLASK_DEBUG=true
SECRET_KEY=change_this_to_a_random_secret_key_in_production

# TrapWeave
TRAPWEAVE_THRESHOLD=0.85
MAX_HONEYPOTS=10
HONEYPOT_SUBNET=192.168.100
API_URL=http://localhost:5000/api

# Frontend
VITE_API_URL=http://localhost:5000/api
